{
  // Frontend (browser) config — governs everything under public/.
  // Provides the DOM libs and NO Node types, so browser code can't accidentally
  // rely on Node globals (process, Buffer, fs, …). Shares all other options with
  // tsconfig.base.json. Backend code lives in tsconfig.server.json.
  //
  // This is the default project config, so editors pick it up for public/*.js.
  // Run the full check (this + the server config) with: npm run typecheck
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": ["public/**/*.js"],
  // Third-party vendored bundle (minified Tailwind CDN build) — not our code and
  // not annotated, so keep it out of the type check. (Repeats node_modules from
  // the base because a child `exclude` replaces rather than merges it.)
  "exclude": ["node_modules", "public/vendor/**"]
}
