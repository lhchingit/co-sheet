# ==============================================================================
# SheetPro Environment Variables Configuration Template
# Copy this file to `.env` and configure your credentials.
# ==============================================================================

# Port number for the Express server to listen on.
PORT=3000

# Base URL of the application. Required in production for OAuth redirect callbacks.
# Local development: http://localhost:3000
# Cloud Run production example: https://sheetpro-service-xxxxxx.run.app
BASE_URL=http://localhost:3000

# PostgreSQL Connection URI.
# Local development example (Docker/Local DB):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cosheet
# Cloud Run production example (Unix socket connection for Google Cloud SQL):
# DATABASE_URL=postgresql://dbuser:dbpass@/dbname?host=/cloudsql/project-id:region:instance-name

# Redis connection URI — enables horizontal scaling (multiple app instances).
# When set, the app shares sessions across instances and fans out edits/cursors
# between them over Redis pub/sub, so you can run more than one replica behind a
# load balancer. Leave UNSET for a single instance (in-memory sessions + in-process
# fan-out); the app behaves exactly as before. The docker-compose stack sets this
# automatically. Local example: redis://localhost:6379
# Use rediss:// for TLS and embed credentials in the URL (redis://user:pass@host:port).
# REDIS_URL=redis://localhost:6379

# Set to "true" ONLY for a true (cluster-mode-enabled) Redis Cluster, which needs a
# slot-aware client. Leave unset for a single endpoint — a standalone Redis or a
# managed HA instance behind one address (Memorystore, ElastiCache cluster-mode-
# disabled). In cluster mode, REDIS_URL may be a comma-separated list of seed nodes.
# REDIS_CLUSTER=false

# Google OAuth 2.0 Credentials (OIDC Strategy).
# Create these credentials in the Google Cloud Console (APIs & Services -> Credentials).
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# "Sign in with Google" toggle (login page button + /auth/google routes). Unlike
# MOCK_OIDC_ENABLED, Google is the primary production sign-in, so it is ENABLED by
# default; leave unset to keep it on. Set to "false" to remove the button AND make
# the /auth/google endpoints return 404, so the option is fully unreachable.
# Accepted falsy values: false, 0, no, off.
# GOOGLE_LOGIN_ENABLED="false"

# ------------------------------------------------------------------------------
# External / self-hosted OIDC provider ("Sign in with Local OIDC").
# Configure these to connect the login page's "Local OIDC" button to a real OIDC
# server (e.g. Keycloak, Authentik, Dex, Zitadel, Okta). When left blank, that
# button is disabled and only the built-in "Mock OIDC" option remains available.
#
# Register a client in your provider with the redirect URI:
#   <BASE_URL>/auth/oidc-sso/callback   (e.g. http://localhost:3000/auth/oidc-sso/callback)
#
# Endpoints can usually be copied from the provider's discovery document at
#   <issuer>/.well-known/openid-configuration
# Keycloak example (realm "myrealm" on localhost:8080):
#   OIDC_ISSUER=http://localhost:8080/realms/myrealm
#   OIDC_AUTHORIZATION_URL=http://localhost:8080/realms/myrealm/protocol/openid-connect/auth
#   OIDC_TOKEN_URL=http://localhost:8080/realms/myrealm/protocol/openid-connect/token
#   OIDC_USERINFO_URL=http://localhost:8080/realms/myrealm/protocol/openid-connect/userinfo
OIDC_ISSUER=""
OIDC_AUTHORIZATION_URL=""
OIDC_TOKEN_URL=""
# Optional: defaults to <OIDC_ISSUER>/userinfo when omitted.
OIDC_USERINFO_URL=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
# Optional: OAuth scopes to request (space-separated). Defaults to "openid profile email".
OIDC_SCOPE="openid profile email"
# Optional: skip the external provider's userinfo call and derive the user's
# identity from the ID-token claims instead. Set to "true" ONLY when the provider
# does not expose a userinfo endpoint (or does not support the `profile` scope) —
# otherwise every login would fail with "Failed to fetch user profile". Leave unset
# / "false" for standard providers. Accepted truthy values: 1, true, yes, on.
OIDC_SKIP_USERINFO="false"
# Optional: TLS certificate verification for the external (Local OIDC) provider's
# token/userinfo calls. Verification is ON by default. Set to "false" ONLY when the
# provider is reached over HTTPS with a self-signed certificate whose CA is not
# installed in this machine's trust store (common for a self-hosted server on a
# trusted LAN). This scopes the skip to the Local OIDC strategy and never affects
# Google or other outbound TLS. Leave unset / "true" in production.
# Accepted falsy values: false, 0, no, off.
OIDC_TLS_VERIFY="true"

# Built-in "Mock OIDC" sign-in (login page button + /oidc and /auth/oidc routes).
# The mock provider needs no external server and is meant for local development &
# tests. When disabled, the button is removed AND the mock endpoints return 404, so
# the mock sign-in is fully unreachable. Leave unset to enable it outside production
# (NODE_ENV !== "production") and disable it in production. Set to "false" to always
# disable, or "true" to always enable. Accepted falsy values: false, 0, no, off.
# MOCK_OIDC_ENABLED="true"

# Super admin bootstrap (permissions page).
# Comma-separated list of emails that are always granted the 'superadmin' role on
# login. Super admins can manage roles and cannot be modified from the UI. For the
# local mock / test sign-in (which has no email) a username may be listed instead.
# Example: SUPER_ADMIN_EMAILS=alice@example.com,bob@example.com
SUPER_ADMIN_EMAILS=""

# ------------------------------------------------------------------------------
# Autosave / version history snapshots.
# The autosave engine periodically captures a version-history snapshot of each
# edited workbook. Cell data is always persisted immediately on every edit; these
# thresholds only govern when a restorable *version* snapshot is recorded. All
# values are in milliseconds.

# Snapshot a workbook this long after the last edit (a pause in editing). Lower it
# for more granular history (a version soon after someone stops typing); raise it
# to record fewer versions. Snapshots are only checked once per polling tick (see
# AUTOSAVE_CHECK_INTERVAL), so the effective delay is this value plus up to one
# tick. Default: 15000 (15s).
# AUTOSAVE_INACTIVITY_LIMIT=15000

# Force a snapshot during continuous editing once this much time has passed since
# the last snapshot, so a long uninterrupted session still produces versions.
# Default: 300000 (5 min).
# AUTOSAVE_ACTIVE_LIMIT=300000

# How often the autosave engine wakes to check whether either threshold above has
# been reached. Default: 10000 (10s).
# AUTOSAVE_CHECK_INTERVAL=10000

# ------------------------------------------------------------------------------
# Real-time WebSocket heartbeat.
# The server periodically pings every connected client and terminates any that
# fail to pong by the next tick (a silently-dropped connection — closed laptop,
# dead network — that never sent a close frame). Reaping it broadcasts a
# user-leave so the client's stale cursor / presence tag is cleared from other
# users' screens. Lower it to clear ghosts faster (at the cost of more ping
# traffic); raise it to reduce chatter. In milliseconds. Default: 30000 (30s).
# WS_HEARTBEAT_MS=30000

# ------------------------------------------------------------------------------
# Prometheus metrics.
# When set, the app starts a SEPARATE HTTP server on this port exposing metrics at
# GET /metrics. The dedicated port keeps /metrics off the public app surface, so it
# can be firewalled to the monitoring network and shares none of the app's
# session/auth middleware. Leave UNSET to disable metrics entirely (no server, no
# per-request overhead). Exposed series: default Node/process metrics (GC, heap,
# event-loop lag, CPU), http_request_duration_seconds (labeled by method/route/
# status), ws_active_connections, active_users, db_up, redis_up.
# METRICS_PORT=9090
