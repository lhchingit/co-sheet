{
  "name": "co-sheet",
  "version": "1.0.0",
  "description": "Real-time collaborative spreadsheet",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node tests/run-integration.mjs",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.server.json",
    "build:css": "tailwindcss -c tailwind/editor.config.cjs -i tailwind/base.css -o public/styles-editor.css --minify && tailwindcss -c tailwind/drive.config.cjs -i tailwind/base.css -o public/styles-drive.css --minify && tailwindcss -c tailwind/login.config.cjs -i tailwind/base.css -o public/styles-login.css --minify"
  },
  "dependencies": {
    "connect-redis": "^9.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "passport": "^0.7.0",
    "passport-openidconnect": "^0.1.2",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "redis": "^5.5.6",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@testcontainers/postgresql": "^12.0.3",
    "@testcontainers/redis": "^12.0.3",
    "@types/node": "^25.9.3",
    "tailwindcss": "^3.4.19",
    "testcontainers": "^12.0.3",
    "typescript": "^6.0.3"
  }
}
